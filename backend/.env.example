# ── Supabase ──────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here
SUPABASE_ANON_KEY=your_anon_key_here

# ── Anthropic ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your_key_here

# ── Reddit API ────────────────────────────────────────
# Register at: https://www.reddit.com/prefs/apps
# Type: script
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USER_AGENT=NicheAgent/1.0 by YourUsername

# ── App settings ──────────────────────────────────────
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app
SECRET_KEY=generate_random_32_char_string_here

# ── Optional: Apify (for Meta Ads + App Store at scale)
# APIFY_API_KEY=your_apify_key

# ── Apify (Reddit scraping without Reddit API) ─────────────────
# Register free at: https://apify.com
# Settings → Integrations → Personal API token
APIFY_API_TOKEN=apify_api_xxxxxxxxxxxxxxxx
